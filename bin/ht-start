#!/usr/bin/env node
"use strict";

const { spawn } = require("child_process");
const { mkdirSync, readFileSync, writeFileSync } = require("fs");
const { homedir } = require("os");
const { join } = require("path");

const REPO = join(homedir(), "code", "hightouch");
const STATE_FILE = join(homedir(), ".local", "state", "ht-start", "last.json");

// cmd defaults to `pnpm run swc:dev <name>` if omitted
// debugPort: enables --inspect on that port (attach from Cursor anytime)
const SERVICES = [
  { name: "scheduler",      debugPort: 9230 },
  { name: "api",            debugPort: 9232 },
  { name: "cdw",            debugPort: 9233 },
  { name: "bcdw",           debugPort: 9234 },
  { name: "plan-executor",  debugPort: 9231 },
  { name: "worker",         debugPort: 9229 },
  { name: "webserver",      cmd: ["node", "../test-webhook-sink/index.js"] },
  { name: "app",            cmd: ["pnpm", "run", "app"] },
];

// ── State ──────────────────────────────────────────────────────────────────

const NAMES = SERVICES.map((s) => s.name);

function loadLast() {
  try {
    return JSON.parse(readFileSync(STATE_FILE, "utf8")).filter((n) =>
      NAMES.includes(n),
    );
  } catch {
    return [];
  }
}

function saveLast(selected) {
  mkdirSync(join(homedir(), ".local", "state", "ht-start"), {
    recursive: true,
  });
  writeFileSync(STATE_FILE, JSON.stringify([...selected]));
}

// ── TUI ───────────────────────────────────────────────────────────────────

const R = "\x1b[0m";
const B = "\x1b[1m";
const DIM = "\x1b[2m";
const GRN = "\x1b[32m";
const REV = "\x1b[7m";

function draw(selected, cursor) {
  let out = "\x1b[2J\x1b[H";
  out += `${B}Start Hightouch services${R}\n`;
  out += `${DIM}↑↓ move   space select   a all   n none   enter launch${R}\n\n`;
  for (let i = 0; i < SERVICES.length; i++) {
    const { name } = SERVICES[i];
    const check = selected.has(name) ? `${GRN}[✓]${R}` : `${DIM}[ ]${R}`;
    const label = i === cursor ? `${REV} ${name} ${R}` : ` ${name}`;
    out += `  ${check}${label}\n`;
  }
  process.stdout.write(out);
}

async function promptServices() {
  const selected = new Set(loadLast());
  let cursor = 0;

  return new Promise((resolve) => {
    process.stdin.setRawMode(true);
    process.stdin.resume();
    process.stdin.setEncoding("utf8");

    draw(selected, cursor);

    function handle(key) {
      const { name } = SERVICES[cursor];
      if (key === "\x03") {
        cleanup();
        process.exit(0);
      } else if (key === "\r") {
        cleanup();
        resolve(selected);
      } else if (key === " ") {
        selected.has(name) ? selected.delete(name) : selected.add(name);
      } else if (key === "\x1b[A") {
        cursor = (cursor - 1 + SERVICES.length) % SERVICES.length;
      } else if (key === "\x1b[B") {
        cursor = (cursor + 1) % SERVICES.length;
      } else if (key === "a" || key === "A") {
        SERVICES.forEach((s) => selected.add(s.name));
      } else if (key === "n" || key === "N") {
        selected.clear();
      } else {
        return;
      }
      draw(selected, cursor);
    }

    function cleanup() {
      process.stdin.removeListener("data", handle);
      process.stdin.setRawMode(false);
      process.stdin.pause();
    }

    process.stdin.on("data", handle);
  });
}

// ── Runner ────────────────────────────────────────────────────────────────

// Color palette for service prefixes
const COLORS = [
  "\x1b[36m",
  "\x1b[33m",
  "\x1b[35m",
  "\x1b[32m",
  "\x1b[34m",
  "\x1b[31m",
];

function startServices(services) {
  const maxLen = Math.max(...services.map((s) => s.name.length));
  const procs = [];

  for (let i = 0; i < services.length; i++) {
    const { name, cmd, debugPort } = services[i];
    const color = COLORS[i % COLORS.length];
    const prefix = color + name.padEnd(maxLen) + R + "  ";

    const [bin, ...args] = cmd ?? ["pnpm", "run", "swc:dev", name];
    const env = { ...process.env, FORCE_COLOR: "1" };
    if (debugPort) env.NODE_OPTIONS = `--inspect=${debugPort}`;
    const proc = spawn(bin, args, {
      cwd: REPO,
      stdio: ["ignore", "pipe", "pipe"],
      env,
    });

    procs.push(proc);

    function printLine(line) {
      process.stdout.write(prefix + line + "\n");
    }

    function attachStream(stream) {
      let buf = "";
      stream.on("data", (chunk) => {
        buf += chunk.toString();
        const lines = buf.split("\n");
        buf = lines.pop(); // keep incomplete line
        lines.forEach(printLine);
      });
      stream.on("end", () => {
        if (buf) printLine(buf);
      });
    }

    attachStream(proc.stdout);
    attachStream(proc.stderr);

    proc.on("exit", (code) => {
      process.stdout.write(`${prefix}${DIM}exited (${code ?? "signal"})${R}\n`);
    });
  }

  // Ctrl+C kills all child processes
  process.on("SIGINT", () => {
    procs.forEach((p) => p.kill("SIGINT"));
    process.exit(0);
  });
}

// ── Main ──────────────────────────────────────────────────────────────────

async function main() {
  const selected = await promptServices();
  process.stdout.write("\x1b[2J\x1b[H");

  if (selected.size === 0) {
    console.log("Nothing selected.");
    return;
  }

  saveLast(selected);

  const toStart = SERVICES.filter((s) => selected.has(s.name));
  startServices(toStart);
}

main().catch((e) => {
  console.error(e);
  process.exit(1);
});
