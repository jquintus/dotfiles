########################################
# Run tests
########################################
# Usage: 
#          pt
#          pt [path to test file]
########################################
pt() {
  local target="."
  if [[ -n "$1" && "$1" != -* ]]; then
    target="$1"; shift
  fi
  local cmd=(uv run pytest "$target" --create-db "$@")
  print -r -- "+ ${cmd[*]}"
  "${cmd[@]}"
}


