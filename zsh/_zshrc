########################################
# This speeds up pasting w/ autosuggest
# https://github.com/zsh-users/zsh-autosuggestions/issues/238
########################################
pasteinit() {
  OLD_SELF_INSERT=${${(s.:.)widgets[self-insert]}[2,3]}
  zle -N self-insert url-quote-magic # I wonder if you'd need `.url-quote-magic`?
}

pastefinish() {
  zle -N self-insert $OLD_SELF_INSERT
}
zstyle :bracketed-paste-magic paste-init pasteinit
zstyle :bracketed-paste-magic paste-finish pastefinish

[[ -s "$HOME/.avn/bin/avn.sh" ]] && source "$HOME/.avn/bin/avn.sh" # load avn

########################################
# Tell less to not page things if there's less than a page anyway
# i.e., this makes "less" act like "cat" if there isn't a full page of text
# https://stackoverflow.com/questions/2183900/how-do-i-prevent-git-diff-from-using-a-pager
########################################
export LESS="-F -X $LESS"

########################################
# peon-ping quick controls
########################################
alias peon="bash /Users/jq/.claude/hooks/peon-ping/peon.sh"
autoload -Uz compinit && compinit -C
[ -f /Users/jq/.claude/hooks/peon-ping/completions.bash ] && source /Users/jq/.claude/hooks/peon-ping/completions.bash
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"

########################################
# History: bigger, deduped, shared across sessions, timestamped.
########################################
HISTSIZE=50000
SAVEHIST=50000
setopt EXTENDED_HISTORY        # record command timestamp + duration
setopt SHARE_HISTORY           # share history live across all open sessions
setopt HIST_IGNORE_ALL_DUPS    # drop older duplicates of a command
setopt HIST_IGNORE_SPACE       # a leading space keeps a command out of history
setopt HIST_REDUCE_BLANKS      # trim superfluous whitespace before saving
setopt HIST_VERIFY             # let me edit a !history expansion before it runs
setopt HIST_FIND_NO_DUPS       # skip dupes when cycling through searches

########################################
# fzf: fuzzy Ctrl-R history search (also Ctrl-T files, Alt-C cd).
########################################
[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ] && source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
[ -f /opt/homebrew/opt/fzf/shell/completion.zsh ]   && source /opt/homebrew/opt/fzf/shell/completion.zsh

########################################
# history-substring-search: type a prefix, then ↑/↓ to cycle matching commands.
########################################
if [ -f /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh ]; then
  source /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh
  zmodload zsh/terminfo 2>/dev/null
  bindkey '^[[A' history-substring-search-up      # up arrow
  bindkey '^[[B' history-substring-search-down    # down arrow
  [[ -n "$terminfo[kcuu1]" ]] && bindkey "$terminfo[kcuu1]" history-substring-search-up    # up (application mode)
  [[ -n "$terminfo[kcud1]" ]] && bindkey "$terminfo[kcud1]" history-substring-search-down  # down (application mode)
fi

########################################
# insert-last-word: Esc-.  (also Alt-. if your terminal sends Option as Meta).
# Repeat to walk back through earlier commands — the classic bash trick.
########################################
bindkey '^[.' insert-last-word

########################################
# Per-host config: source zsh/_zshrc-<hostname> if it exists.
# Use scutil LocalHostName on macOS — `hostname` reflects the transient DHCP
# name and drifts with the network; LocalHostName is the stable machine name.
########################################
# Absolute path + zsh's built-in $HOST so this never depends on PATH being
# fully set up (a `source ~/.zshrc` reload skips /etc/zprofile's path_helper).
_host=$(/usr/sbin/scutil --get LocalHostName 2>/dev/null || echo ${HOST%%.*})
_host_zshrc=~/dotfiles/zsh/_zshrc-$_host
[[ -f "$_host_zshrc" ]] && source "$_host_zshrc"
unset _host_zshrc _host

########################################
# config: open/reload shell config files (convention: zsh/_zshrc-<name>)
#   config            fzf picker over all config files
#   config dirty      edit zsh/_zshrc-dirty   (this host's config)
#   config aliases    edit zsh/_zshrc-aliases
#   config zshrc      edit the base rc
#   config db         edit ~/.config/zsh/db.local.zsh (local DB connections)
#   config -reload    re-source ~/.zshrc
# Defined after compinit so `compdef` is available for completion.
########################################
config() {
  local zdir=~/dotfiles/zsh
  case "$1" in
    -reload|--reload|reload)
      source ~/.zshrc && echo "reloaded ~/.zshrc" ;;
    "")
      local pick
      pick=$( { command ls -d "$zdir"/_zshrc* 2>/dev/null | grep -v zwc
        [[ -f ~/.config/zsh/db.local.zsh ]] && echo ~/.config/zsh/db.local.zsh; } |
        fzf --prompt='config ❯ ' --height=40% --reverse) &&
        "${EDITOR:-nvim}" "$pick" ;;
    zshrc|rc)
      "${EDITOR:-nvim}" "$zdir/_zshrc" ;;
    db)
      "${EDITOR:-nvim}" ~/.config/zsh/db.local.zsh ;;
    *)
      local f="$zdir/_zshrc-$1"
      if [[ -f "$f" ]]; then
        "${EDITOR:-nvim}" "$f"
      else
        print -u2 "config: no config named '$1'  ($f)"
        print -u2 "try: config           (picker)   |   config -reload"
        return 1
      fi ;;
  esac
}

_config() {
  local zdir=~/dotfiles/zsh
  local -a names
  names=(${(f)"$(command ls "$zdir" | grep -E '^_zshrc' | grep -v zwc |
    sed -E 's/^_zshrc-//; s/^_zshrc$/zshrc/')"})
  compadd -- reload db $names
}
compdef _config config

########################################
# Fast reload: `rl` alias, or Ctrl-X Ctrl-R.
# `exec zsh` replaces the shell with a fresh one (cleaner than re-sourcing;
# combined with `typeset -U path` above, PATH stays deduped across reloads).
########################################
alias rl='exec zsh'
_reload_shell() { BUFFER='exec zsh'; zle accept-line }
zle -N _reload_shell
bindkey '^X^R' _reload_shell

########################################
# Starship prompt (config: ~/.config/starship.toml -> dotfiles/starship.toml)
########################################
command -v starship >/dev/null && eval "$(starship init zsh)"

